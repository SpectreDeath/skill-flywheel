      "implementation_patterns": [
        {
          "pattern": "Windowed Aggregation",
          "description": "Aggregate data within time windows with proper handling of late arrivals",
          "code_template": "windowed = pcoll | beam.WindowInto(FixedWindows(size), allowed_lateness=lateness, trigger=AfterWatermark(early=AfterProcessingTime(10)))",
