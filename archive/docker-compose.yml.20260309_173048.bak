networks:
  mcp-network:
    driver: bridge
services:
  mcp-advanced:
    environment:
    - PORT=8007
    - REGISTRY_FILE=/app/skill_registry.json
    - MCP_CONFIG_FILE=/app/mcp_config.json
    image: skill-flywheel/mcp-advanced:latest
    networks:
    - mcp-network
    ports:
    - 8007:8007
    restart: unless-stopped
    volumes:
    - ./skill_registry.json:/app/skill_registry.json
    - ./mcp_config.json:/app/mcp_config.json
  mcp-agent-rd:
    environment:
    - PORT=8009
    - REGISTRY_FILE=/app/skill_registry.json
    - MCP_CONFIG_FILE=/app/mcp_config.json
    image: skill-flywheel/mcp-agent-rd:latest
    networks:
    - mcp-network
    ports:
    - 8009:8009
    restart: unless-stopped
    volumes:
    - ./skill_registry.json:/app/skill_registry.json
    - ./mcp_config.json:/app/mcp_config.json
  mcp-data-ai:
    environment:
    - PORT=8003
    - REGISTRY_FILE=/app/skill_registry.json
    - MCP_CONFIG_FILE=/app/mcp_config.json
    image: skill-flywheel/mcp-data-ai:latest
    networks:
    - mcp-network
    ports:
    - 8003:8003
    restart: unless-stopped
    volumes:
    - ./skill_registry.json:/app/skill_registry.json
    - ./mcp_config.json:/app/mcp_config.json
  mcp-devops:
    environment:
    - PORT=8004
    - REGISTRY_FILE=/app/skill_registry.json
    - MCP_CONFIG_FILE=/app/mcp_config.json
    image: skill-flywheel/mcp-devops:latest
    networks:
    - mcp-network
    ports:
    - 8004:8004
    restart: unless-stopped
    volumes:
    - ./skill_registry.json:/app/skill_registry.json
    - ./mcp_config.json:/app/mcp_config.json
  mcp-discovery:
    environment:
    - PORT=8000
    - REGISTRY_FILE=/app/skill_registry.json
    - MCP_CONFIG_FILE=/app/mcp_config.json
    - DOCKER_COMPOSE_FILE=/app/docker-compose.yml
    image: skill-flywheel/mcp-discovery:latest
    networks:
    - mcp-network
    ports:
    - 8000:8000
    restart: unless-stopped
    volumes:
    - ./skill_registry.json:/app/skill_registry.json
    - ./mcp_config.json:/app/mcp_config.json
    - ./docker-compose.yml:/app/docker-compose.yml
  mcp-engineering:
    environment:
    - PORT=8005
    - REGISTRY_FILE=/app/skill_registry.json
    - MCP_CONFIG_FILE=/app/mcp_config.json
    image: skill-flywheel/mcp-engineering:latest
    networks:
    - mcp-network
    ports:
    - 8005:8005
    restart: unless-stopped
    volumes:
    - ./skill_registry.json:/app/skill_registry.json
    - ./mcp_config.json:/app/mcp_config.json
  mcp-fallback:
    environment:
    - PORT=8000
    - REGISTRY_FILE=/app/skill_registry.json
    - MCP_CONFIG_FILE=/app/mcp_config.json
    image: skill-flywheel/mcp-fallback:latest
    networks:
    - mcp-network
    ports:
    - 8000:8000
    restart: unless-stopped
    volumes:
    - ./skill_registry.json:/app/skill_registry.json
    - ./mcp_config.json:/app/mcp_config.json
  mcp-model-orchestration:
    environment:
    - PORT=8012
    - REGISTRY_FILE=/app/skill_registry.json
    - MCP_CONFIG_FILE=/app/mcp_config.json
    image: skill-flywheel/mcp-model-orchestration:latest
    networks:
    - mcp-network
    ports:
    - 8012:8012
    restart: unless-stopped
    volumes:
    - ./skill_registry.json:/app/skill_registry.json
    - ./mcp_config.json:/app/mcp_config.json
  mcp-orchestration:
    environment:
    - PORT=8001
    - REGISTRY_FILE=/app/skill_registry.json
    - MCP_CONFIG_FILE=/app/mcp_config.json
    image: skill-flywheel/mcp-orchestration:latest
    networks:
    - mcp-network
    ports:
    - 8001:8001
    restart: unless-stopped
    volumes:
    - ./skill_registry.json:/app/skill_registry.json
    - ./mcp_config.json:/app/mcp_config.json
  mcp-security:
    environment:
    - PORT=8002
    - REGISTRY_FILE=/app/skill_registry.json
    - MCP_CONFIG_FILE=/app/mcp_config.json
    image: skill-flywheel/mcp-security:latest
    networks:
    - mcp-network
    ports:
    - 8002:8002
    restart: unless-stopped
    volumes:
    - ./skill_registry.json:/app/skill_registry.json
    - ./mcp_config.json:/app/mcp_config.json
  mcp-strategy:
    environment:
    - PORT=8008
    - REGISTRY_FILE=/app/skill_registry.json
    - MCP_CONFIG_FILE=/app/mcp_config.json
    image: skill-flywheel/mcp-strategy:latest
    networks:
    - mcp-network
    ports:
    - 8008:8008
    restart: unless-stopped
    volumes:
    - ./skill_registry.json:/app/skill_registry.json
    - ./mcp_config.json:/app/mcp_config.json
  mcp-ux-mobile:
    environment:
    - PORT=8006
    - REGISTRY_FILE=/app/skill_registry.json
    - MCP_CONFIG_FILE=/app/mcp_config.json
    image: skill-flywheel/mcp-ux-mobile:latest
    networks:
    - mcp-network
    ports:
    - 8006:8006
    restart: unless-stopped
    volumes:
    - ./skill_registry.json:/app/skill_registry.json
    - ./mcp_config.json:/app/mcp_config.json
version: '3.8'
