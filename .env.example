# Skill Flywheel Environment Configuration
# Copy this file to .env and fill in your actual values
# NEVER commit .env to version control

# API Keys for LLM providers
OPENAI_API_KEY=your_openai_api_key_here
GEMINI_API_KEY=your_gemini_api_key_here

# Security - use a strong random secret (minimum 32 characters)
MCP_JWT_SECRET=your_secure_jwt_secret_min_32_chars

# Discovery Service Configuration (optional)
# PORT=8000
# REGISTRY_FILE=skill_registry.json
# MCP_CONFIG_FILE=mcp_config.json
